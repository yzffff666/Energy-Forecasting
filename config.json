{
  "experiment_name": "xgboost_baseline",
  "random_seed": 42,
  "data": {
    "input_path": "data/Native_Load_2025.zip",
    "archive_member": "Native_Load_2025.xlsx",
    "sheet_name": 0,
    "timestamp_col": "Hour Ending",
    "target_col": "ERCOT",
    "feature_cols": [],
    "freq": "h"
  },
  "features": {
    "lags": [1, 2, 3, 24, 48, 168],
    "rolling_windows": [24, 168],
    "add_calendar_features": true
  },
  "split": {
    "train_frac": 0.7,
    "val_frac": 0.15,
    "test_frac": 0.15
  },
  "model": {
    "name": "xgboost",
    "params": {
      "n_estimators": 400,
      "learning_rate": 0.05,
      "max_depth": 6,
      "subsample": 1.0,
      "colsample_bytree": 1.0,
      "reg_alpha": 0.0,
      "reg_lambda": 1.0,
      "objective": "reg:squarederror",
      "random_state": 42,
      "n_jobs": 1
    }
  },
  "baselines": {
    "persistence_lags": [1, 24]
  },
  "uncertainty": {
    "enabled": true,
    "quantiles": [0.1, 0.9],
    "fallback_to_residual_interval": true
  },
  "results": {
    "output_dir": "results",
    "plot_last_n": 336
  }
}
